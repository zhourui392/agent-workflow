{
  "name": "agent-workflow",
  "version": "1.0.0",
  "description": "AI-driven multi-step workflow automation platform",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"npm run build:main -- --watch\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:main && npm run build:renderer && electron-builder",
    "type-check": "tsc --noEmit",
    "test": "npm run test:core && npm run test:config && npm run test:pipeline",
    "test:core": "npx ts-node test/test-core.ts",
    "test:config": "npx ts-node test/test-config.ts",
    "test:pipeline": "npx ts-node test/test-pipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.0.0",
    "electron-log": "^5.0.0",
    "element-plus": "^2.9.1",
    "node-cron": "^3.0.3",
    "pinia": "^2.3.0",
    "uuid": "^9.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.agentworkflow.app",
    "productName": "Agent Workflow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "global_config/**/*"
    ],
    "extraResources": [
      {
        "from": "global_config",
        "to": "global_config"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
